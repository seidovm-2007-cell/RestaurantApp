*.zip
*.rar
*.7z
*.tar
*.gz

# 6. КОНФИГУРАЦИИ IDE
.idea/
.vscode/
*.code-workspace

# 7. ФАЙЛЫ ДОКУМЕНТАЦИИ (НЕ ИСХОДНИКИ)
